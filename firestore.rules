rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'cristiandwihariantoro@gmail.com'
      );
    }

    function isValidVideo(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.video_url is string && data.video_url.size() <= 1000 &&
             data.thumbnail_url is string && data.thumbnail_url.size() <= 1000;
    }

    // Videos collection
    match /videos/{videoId} {
      // Public can read list and single documents
      allow read: if true;
      
      // Only admins can create, update, or delete
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && (
        // Allow all updates for admin if schema is valid
        isValidVideo(request.resource.data)
      );
      allow delete: if isAdmin();
    }
  }
}
