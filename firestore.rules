rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidVideo(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.video_url is string && data.video_url.size() <= 1000 &&
             data.thumbnail_url is string && data.thumbnail_url.size() <= 1000;
    }

    // Videos collection
    match /videos/{videoId} {
      // Allowing public read and write since the user switched to a custom password system
      // and disabled standard Firebase Authentication for login simplicity.
      allow read, write: if true;
    }
  }
}
